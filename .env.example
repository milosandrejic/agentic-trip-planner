# --- App ---
APP_ENV=development
PORT=8000
LOG_LEVEL=info

# --- Database (Postgres) ---
# Inside Docker the host is 'db'; from your host machine use localhost:5433
DATABASE_URL=postgresql+asyncpg://trip_planner:trip_planner@db:5432/trip_planner

# --- Auth (Phase 1) ---
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# --- LLM / Agents (Phase 2+) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Tools (Phase 3) ---
TAVILY_API_KEY=

# --- Observability (Phase 2+) ---
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agentic-trip-planner
